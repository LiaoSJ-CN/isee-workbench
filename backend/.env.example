# iSee Data Analysis Workbench — Backend Configuration
# Copy this file to .env and adjust values for your deployment.

# Application display name
APP_NAME=iSee Data Analysis Workbench

# FastAPI debug mode — set to false in production
DEBUG=false

# Metadata database URL (SQLite for single-node, PostgreSQL for multi-node)
# SQLite:  sqlite:///./app.db
# PostgreSQL: postgresql://user:password@host:5432/dbname
DATABASE_URL=sqlite:///./app.db

# Allowed CORS origins (JSON array of strings)
# Add your frontend URLs here if the frontend is served from a different origin.
CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]

# --- Auth ---
# Change these in production!
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme

# JWT signing key — generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
# REQUIRED for production. Without it, all tokens are invalidated on every restart.
JWT_SECRET_KEY=

# JWT algorithm (HS256 is fine for single-service deployments)
JWT_ALGORITHM=HS256

# Token lifetimes
ACCESS_TOKEN_MINUTES=1440   # 24 hours
REFRESH_TOKEN_DAYS=7        # 7 days

# --- Brute-force protection ---
# Max login attempts per IP per minute before returning HTTP 429
LOGIN_RATE_LIMIT=10

# --- Database connection pool ---
# Only applied when DATABASE_URL is not SQLite (SQLite uses a single-connection NullPool).
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10

# --- Data-source password encryption at rest ---
# Fernet key — generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# REQUIRED for production. Changing this key makes existing encrypted passwords unreadable.
ENCRYPTION_KEY=

# --- Scheduler ---
# Sidecar deployment mode (recommended for production):
#   Web process:     SCHEDULER_DISABLED=true  (default)
#   Sidecar process: run `python -m app.scheduler_runner` as a separate process
# Single-process dev mode:
#   Set SCHEDULER_DISABLED=false to run the scheduler inside the web process.
SCHEDULER_DISABLED=true
SCHEDULER_RESYNC_INTERVAL=30

# --- Report output ---
# Directory for generated report files (HTML / Excel).
# Defaults to backend/generated_reports/ if left empty.
# GENERATED_REPORTS_DIR=

# --- Logging ---
# DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
